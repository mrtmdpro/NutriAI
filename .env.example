# NutriAI environment variables. Copy to .env.local and fill in values.
# After Vercel link + Supabase Marketplace install, prefer:
#   vercel env pull .env.local

# --- Supabase ---
# When provisioning manually (https://supabase.com), copy these from
# Settings → API in the Supabase dashboard. The "anon" / "publishable"
# key is browser-safe; the "service_role" / "secret" key is NEVER.
# Either NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY (new name, sb_publishable_*)
# or NEXT_PUBLIC_SUPABASE_ANON_KEY (legacy) is read.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Vercel AI Gateway (RAG chat + embeddings + bilingual summarization) ---
AI_GATEWAY_API_KEY=

# --- Email reminders (BR2) ---
RESEND_API_KEY=

# --- Stitch design generation (used by scripts/stitch-generate.ts) ---
STITCH_API_KEY=

# --- SePay.vn payment gateway (BR2 monetization) ---
SEPAY_API_KEY=
SEPAY_BANK_ACCOUNT=
SEPAY_BANK_NAME=
SEPAY_ACCOUNT_HOLDER=

# --- Web Push (VAPID) for adherence reminders ---
# Generate with: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_CONTACT_EMAIL=

# --- Vercel cron auth ---
# Random string used to authenticate cron jobs hitting /api/cron/*
CRON_SECRET=

# --- Public site URL (used for sitemap, OG, OAuth callbacks) ---
NEXT_PUBLIC_SITE_URL=
